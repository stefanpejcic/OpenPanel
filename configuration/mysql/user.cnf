[mysqld]
skip-name-resolve

# Connections (sized for a 1G container, update it as needed)
max_connections         = 100
thread_cache_size       = 16
wait_timeout            = 120
interactive_timeout     = 120

# InnoDB
innodb_buffer_pool_size        = 512M
innodb_flush_log_at_trx_commit = 2
innodb_file_per_table          = 1

# MyISAM
key_buffer_size          = 32M

skip-log-bin
