# general
{   
    #admin off

    cert_issuer acme {
        ca https://acme-v02.api.letsencrypt.org/directory
    }

    cert_issuer zerossl {
        ca https://acme.zerossl.com/v2/DV90
    }

    renew_interval 30m
    ocsp_interval 3h

    on_demand_tls {
        ask "http://localhost/check"
    }
}

# START HOSTNAME DOMAIN #
example.net {
    reverse_proxy localhost:2087
}

http://example.net {
    reverse_proxy localhost:2087
}
# END HOSTNAME DOMAIN #

# START WEBMAIL DOMAIN #
webmail.example.net {
    reverse_proxy localhost:8080
}
# END WEBMAIL DOMAIN #

# import /check route
import /etc/openpanel/caddy/check.conf

# import wp-manager rules
import /etc/openpanel/caddy/templates/wp.rules

# import all sites
import /etc/openpanel/caddy/domains/*
