# ========================================
#    Logs actual IP behind Cloudflare
# ========================================
(cloudflare_trusted_proxies) {
    # Trust Cloudflare IP ranges
    trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22
    trusted_proxies static 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20
    trusted_proxies static 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13
    trusted_proxies static 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22

    # also trust IPv6 ranges
    trusted_proxies static 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
}

# usage:
# in Caddyfile add this before importing domains: 
#      import /etc/openpanel/caddy/templates/cf.proxy
# and then in every vhost file per domain, insert under every reverse_proxy section:
#      import cloudflare_trusted_proxies
