msgid "WP_DEBUG_LOG"
msgstr "WP_DEBUG_LOG"

#: templates/manager/wp/single.html:1661
msgid "Save all errors to the debug.log file inside the wp-content directory."
msgstr "ບັນທຶກຂໍ້ຜິດພາດທັງໝົດລົງໃນໄຟລ໌ debug.log ພາຍໃນໄດເຣັກທໍຣີ wp-content."

#: templates/manager/wp/single.html:1670
msgid "Enable WP_DEBUG_LOG"
msgstr "ເປີດໃຊ້ WP_DEBUG_LOG"

#: templates/manager/wp/single.html:1684 templates/manager/wp/single.html:1691
